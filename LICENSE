━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
第 1 条 · 授权与开源
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1.1  本软件 100% 开源。源代码随每次发布公开托管于主力仓库
     https://github.com/tvvshow/kan-mine ，任何人均可自由审阅、
     学习、研究、在本机或自有矿机上运行。

1.2  本软件的算力输出对矿工 100% 透明：**零开发费 / 零抽水
     （Zero Dev Fee / Zero Hashrate Skimming）**。即：

     (a) 本软件运行时不向任何作者钱包、开发者地址、第三方地址
         转移份额或偷算力；
     (b) 矿工提交给矿池的全部有效 share 所对应的收益归矿工本人所有；
     (c) 源代码中不含任何隐藏的算力分流、share 重定向、延迟提交、
         "1% devfee" 之类的逻辑，欢迎审计源码核对。

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
第 2 条 · 禁止商用
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

2.1  本软件仅授权用于**个人非商业用途**（personal non-commercial use）。
     个人矿工使用自有 GPU 在自有矿池账号上挖矿属于授权范围。

2.2  **严禁任何形式的商业使用**，包括但不限于：
     (a) 将本软件作为收费服务、托管服务、云算力产品对外提供；
     (b) 将本软件打包进任何收费的矿工套件、管理面板、商业化发行版；
     (c) 以盈利为目的，运营本软件构成的矿场 / 矿池节点；
     (d) 以任何直接或间接盈利为目的销售、转售、出租、分发本软件。

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
第 3 条 · 禁止加入抽水 / 禁止篡改收益分配
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

3.1  在对本软件进行二次开发、修改、分支、再分发时，**严禁加入
     任何形式的抽水机制**，包括但不限于：

     (a) 开发费 / devfee（无论百分比多低）；
     (b) 算力分流（把部分 share / hash 重定向到非矿工指定的地址）；
     (c) 延迟或选择性提交 share 以克扣收益；
     (d) 在 wallet / worker / pool 字段上做手脚以窃取算力；
     (e) 任何使"实际提交给矿池的算力"少于"矿机实际产生的算力"
         的隐藏逻辑。

3.2  任何违反第 3.1 条的衍生版本，其在本许可下的授权自动终止，
     且原作者保留追究责任的权利。

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
第 4 条 · 二次开发必须标注出处
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

4.1  允许学习、研究、修改本软件（fork / 二次开发），但任何衍生作品
     （modified version / fork / 再分发）**必须同时满足**：

     (a) **显著标注出处**：在衍生作品的 README、启动横幅、--version
         输出、关于页面等用户可见位置，注明"Based on Kan by
         tvvshow/kan-mine (https://github.com/tvvshow/kan-mine)"；
     (b) **保留本 LICENSE 文件全文**，不得删除或弱化第 2、3 条
         （禁商用、禁抽水）；
     (c) **以相同的本许可条款**（禁商用 + 禁抽水 + 标出处）发布衍生
         作品，不得改为 MIT / Apache / GPL 等允许商用或允许闭源的
         许可；
     (d) 衍生作品的任何公开分发，必须同时公开其完整源代码
         （不得发布"只给二进制、不给源码"的闭源魔改版）。

4.2  违反第 4.1 条任一款的衍生作品，即视为未获授权，其分发与
     使用均构成侵权。

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
第 5 条 · 免责声明
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

5.1  本软件按"现状"（AS IS）提供，不附带任何明示或默示的担保。
     使用本软件的风险由使用者自行承担。

5.2  作者不对因使用本软件而产生的任何直接或间接损失（包括但不限于
     算力损失、收益损失、硬件损坏、数据丢失）承担责任。

5.3  使用本软件应遵守您所在司法管辖区及矿池的相关法律法规。
     因违反法律法规或矿池规则而产生的后果，由使用者自行承担。

